-- FUNÇÕES
local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function attack()
	local char = getCharacter()
	for _, tool in pairs(char:GetChildren()) do
		if tool:IsA("Tool") then
			tool:Activate()
		end
	end
end

