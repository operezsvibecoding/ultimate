	if h then
		if tonumber(ws.Text) then h.WalkSpeed=tonumber(ws.Text) end
		if tonumber(jp.Text) then h.JumpPower=tonumber(jp.Text) end
	end
end)

-- FLY
flyBtn.MouseButton1Click:Connect(function()
	flying=not flying
	flyBtn.Text="Fly: "..(flying and "ON" or "OFF")

	local hrp=getCharacter():WaitForChild("HumanoidRootPart")

	if flying then
		bodyVel=Instance.new("BodyVelocity",hrp)
		bodyVel.MaxForce=Vector3.new(1e9,1e9,1e9)

		RunService.RenderStepped:Connect(function()
			if flying and bodyVel then
				local cam=workspace.CurrentCamera
				local speed=tonumber(flySpeedBox.Text) or 50
				
				local dir =
					(cam.CFrame.LookVector * -moveDir.Z) +
					(cam.CFrame.RightVector * moveDir.X) +
					Vector3.new(0,moveDir.Y,0)

				bodyVel.Velocity = dir * speed
			end
		end)
	else
		if bodyVel then bodyVel:Destroy() end
	end
end)

-- NOCLIP
noclipBtn.MouseButton1Click:Connect(function()
	noclip=not noclip
	noclipBtn.Text="Noclip: "..(noclip and "ON" or "OFF")
end)

RunService.Stepped:Connect(function()
	if noclip then
		for _,v in pairs(getCharacter():GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide=false
			end
		end
	end
end)

