-- INIMIGOS
local function getEnemies()
	local t={}
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") then
			local h=v:FindFirstChildOfClass("Humanoid")
			if h and h.Health>0 then table.insert(t,v) end
		end
	end
	return t
end

local function render(f)
	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end
	
	for _,e in pairs(allEnemies) do
		if f=="" or string.find(string.lower(e.Name),string.lower(f)) then
			local b=Instance.new("TextButton",scroll)
			b.Size=UDim2.new(1,0,0,30)
			b.Text=e.Name
			styleButton(b)

			b.MouseButton1Click:Connect(function()
				if selectedEnemies[e] then
					selectedEnemies[e]=nil
					b.BackgroundColor3=Color3.fromRGB(40,40,40)
				else
					selectedEnemies[e]=true
					b.BackgroundColor3=Color3.fromRGB(70,70,70)
				end
			end)
		end
	end
	
	task.wait()
	scroll.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end

local function refresh()
	allEnemies=getEnemies()
	render(search.Text)
end

search:GetPropertyChangedSignal("Text"):Connect(function()
	render(search.Text)
end)

refreshBtn.MouseButton1Click:Connect(function()
	selectedEnemies={}
	refresh()
end)

-- LOOP PRINCIPAL (CORRIGIDO)
RunService.RenderStepped:Connect(function()
	if not running then return end

	currentTarget = nil

	for e,_ in pairs(selectedEnemies) do
		if e and e.Parent then
			local hum = e:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				currentTarget = e
				break
			end
		end
	end

	if currentTarget then
		local hrp = currentTarget:FindFirstChild("HumanoidRootPart")
		local char = getCharacter()
		local my = char:FindFirstChild("HumanoidRootPart")

		if hrp and my then
			my.CFrame = hrp.CFrame * CFrame.new(0, -17, 0)
			attack()
		end
	end
end)

